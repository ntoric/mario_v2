{
  "name": "cafe-order-management",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "homepage": ".",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:backend": "cd backend-go && mkdir -p build && GOOS=darwin GOARCH=arm64 go build -ldflags='-s -w' -o build/cafe-backend-darwin-arm64 cmd/server/main.go",
    "preview": "vite preview",
    "build:printer": "cd printer_service && ./build.sh",
    "build:printer:mac": "cd printer_service && GOOS=darwin GOARCH=arm64 go build -ldflags='-s -w' -o build/printer-service-darwin-arm64",
    "prepare:env": "node scripts/prepare-env.js",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build:mac": "npm run prepare:env && npm run build && npm run build:backend && npm run build:printer:mac && electron-builder --mac",
    "electron:build:mac:arm64": "npm run prepare:env && npm run build && npm run build:backend && npm run build:printer:mac && electron-builder --mac --arm64",
    "electron:pack": "npm run prepare:env && npm run build && npm run build:backend && npm run build:printer && electron-builder --dir",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "postinstall": "cd backend && npm install"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "uuid": "^9.0.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cafe.manager",
    "productName": "Cafe Manager",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules/**/*",
      "!backend/**/*",
      "!backend-go/**/*",
      "!printer_service/**/*",
      "!scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-go/build",
        "to": "backend-go",
        "filter": ["cafe-backend-darwin-arm64"]
      },
      {
        "from": "printer_service/build",
        "to": "printer_service/build",
        "filter": ["printer-service-darwin-arm64"]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        },
        {
          "target": "zip",
          "arch": ["arm64"]
        }
      ],
      "category": "public.app-category.business",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "compression": "maximum",
    "asar": true,
    "asarUnpack": [
      "**/backend-go/**/*",
      "**/printer_service/**/*"
    ]
  }
}
