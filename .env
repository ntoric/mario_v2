# Frontend Environment Variables
# These variables are exposed to the client-side code
# Must start with VITE_ to be accessible

# API URL - Change this to your backend server URL
VITE_API_URL=http://localhost:3001/api

# App Configuration
VITE_APP_NAME=Cafe Manager
VITE_APP_VERSION=1.0.0


# Database
DB_HOST=mario-pgbouncer2.ntoric.com
DB_PORT=6432
DB_NAME=mariodb
DB_USER=mariodbuser
DB_PASSWORD=mariodbpassword

# JWT
JWT_SECRET=your-super-secret-key-change-in-production

# Server
PORT=3001
NODE_ENV=development

# Super Admin Credentials
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin123
SUPERADMIN_NAME=Super Administrator

# Printer Service
PRINTER_SERVICE_URL=http://localhost:8085
